# Copy to .env and fill in. .env is gitignored.
# Local dev (Postgres on localhost, trust auth):
DATABASE_URL="postgresql://USER@localhost:5432/ecom_dev?schema=public"
# Shadow DB used by `prisma migrate dev` for drift detection (must be a separate empty DB):
SHADOW_DATABASE_URL="postgresql://USER@localhost:5432/ecom_shadow?schema=public"
